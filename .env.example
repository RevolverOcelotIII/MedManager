# --- Database (Postgres) ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=password_cool
POSTGRES_DB=hospital_db

# --- Backend (FastAPI) ---
# Primary database connection
DATABASE_URL=postgresql://admin:password_cool@db:5432/hospital_db

# Testing database connection (used by pytest)
TEST_DATABASE_URL=postgresql://admin:password_cool@db:5432/test_db

# Redis connection for caching
REDIS_URL=redis://medmanager_redis:6379

# Security & Authentication
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your_super_secret_random_hex_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS & Redirects
FRONT_URL=http://localhost:3000

# --- Frontend (Next.js) ---
# Public URL of the API (must be accessible from the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
